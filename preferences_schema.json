{
  "questionnaire": {
    "version": "2.0",
    "language": "en",
    "sections": [
      {
        "id": "investment_goal",
        "name": "What is your main goal with this investment?",
        "type": "single_select",
        "required": true,
        "options": [
          {
            "id": "wealth_building",
            "label": "Build wealth for your dreams and aspirations",
            "value": "wealth_building"
          },
          {
            "id": "retirement",
            "label": "Secure your retirement income",
            "value": "retirement"
          },
          {
            "id": "home_ownership",
            "label": "Save for your own home",
            "value": "home_ownership"
          },
          {
            "id": "wealth_transfer",
            "label": "Pass on wealth to the next generation",
            "value": "wealth_transfer"
          }
        ]
      },
      {
        "id": "investment_duration",
        "name": "How long are you planning to invest for?",
        "type": "single_select",
        "required": true,
        "options": [
          {
            "id": "short_term",
            "label": "Up to 12 years",
            "value": "0_12_years"
          },
          {
            "id": "medium_term",
            "label": "12 to 20 years",
            "value": "12_20_years"
          },
          {
            "id": "long_term",
            "label": "Over 20 years",
            "value": "20_plus_years"
          }
        ]
      },
      {
        "id": "monthly_savings",
        "name": "How much can you save each month?",
        "type": "single_select",
        "required": true,
        "options": [
          {
            "id": "micro",
            "label": "€0 to €150",
            "value": "0_150",
            "currency": "EUR"
          },
          {
            "id": "modest",
            "label": "€150 to €300",
            "value": "150_300",
            "currency": "EUR"
          },
          {
            "id": "moderate",
            "label": "€300 to €500",
            "value": "300_500",
            "currency": "EUR"
          },
          {
            "id": "substantial",
            "label": "Over €500",
            "value": "500_plus",
            "currency": "EUR"
          },
          {
            "id": "no_answer",
            "label": "Prefer not to say",
            "value": "no_answer"
          }
        ]
      },
      {
        "id": "investment_experience",
        "name": "Have you invested in any of these before?",
        "type": "multi_select",
        "required": false,
        "options": [
          {
            "id": "insurance",
            "label": "Life insurance or pension plans",
            "value": "life_insurance"
          },
          {
            "id": "funds",
            "label": "Investment funds (shares, bonds or mixed funds)",
            "value": "investment_funds"
          },
          {
            "id": "alternative",
            "label": "Alternative investments",
            "value": "alternative_investments"
          },
          {
            "id": "no_experience",
            "label": "I'm new to this – and that's perfectly fine!",
            "value": "no_experience"
          }
        ]
      },
      {
        "id": "investment_knowledge",
        "name": "How would you describe your investment knowledge?",
        "type": "single_select",
        "required": true,
        "options": [
          {
            "id": "confident",
            "label": "Yes, I'm quite confident with investments",
            "value": "experienced"
          },
          {
            "id": "beginner",
            "label": "No, I'm just starting out",
            "value": "beginner"
          }
        ]
      },
      {
        "id": "risk_approach",
        "name": "Which investment approach appeals to you most?",
        "type": "single_select",
        "required": true,
        "options": [
          {
            "id": "conservative",
            "label": "Security matters most – I want steady, predictable growth",
            "value": "conservative",
            "risk_profile": 1,
            "optimizer_profile": "DEFENSIVE"
          },
          {
            "id": "moderate_low",
            "label": "I value security, but I'm also open to modest growth opportunities",
            "value": "moderate_low",
            "risk_profile": 2,
            "optimizer_profile": "DEFENSIVE"
          },
          {
            "id": "moderate",
            "label": "I can accept some fluctuations for better returns, but I'd like some protection of my contributions",
            "value": "moderate",
            "risk_profile": 3,
            "optimizer_profile": "BALANCED"
          },
          {
            "id": "aggressive",
            "label": "I'm comfortable taking on risk for better growth prospects, and I accept potential losses",
            "value": "aggressive",
            "risk_profile": 4,
            "optimizer_profile": "OPPORTUNITY"
          }
        ]
      },
      {
        "id": "loss_tolerance",
        "name": "Can you afford financial losses?",
        "type": "single_select",
        "required": true,
        "options": [
          {
            "id": "low_tolerance",
            "label": "I need strong guarantees and want to minimise the risk of losses",
            "value": "low_loss_tolerance",
            "loss_tolerance_score": 1
          },
          {
            "id": "high_tolerance",
            "label": "I'm in a solid financial position to handle larger losses if needed",
            "value": "high_loss_tolerance",
            "loss_tolerance_score": 4
          }
        ]
      },
      {
        "id": "esg_preference",
        "name": "How important is sustainability to you?",
        "description": "ESG stands for Environmental, Social & Governance – it measures how responsibly a company operates.",
        "type": "single_select",
        "required": true,
        "options": [
          {
            "id": "no_esg_requirement",
            "label": "It's not a priority – focus on performance",
            "value": "no_requirement",
            "esg_requirement": "NONE",
            "esg_level": null
          },
          {
            "id": "esg_basic",
            "label": "I'd like some sustainability standards (Article 8 funds and above)",
            "value": "esg_basic",
            "esg_requirement": "REQUIRED",
            "esg_level": "BASIC"
          },
          {
            "id": "esg_enhanced",
            "label": "Sustainability is very important to me (Article 9 / high-impact funds only)",
            "value": "esg_enhanced",
            "esg_requirement": "REQUIRED",
            "esg_level": "ENHANCED"
          }
        ]
      },
      {
        "id": "etf_preference",
        "name": "Do you have a preference for ETFs (index-tracking funds)?",
        "description": "ETFs are typically lower-cost and transparent. Actively managed funds aim to beat the market but charge higher fees.",
        "type": "single_select",
        "required": true,
        "options": [
          {
            "id": "no_etf_preference",
            "label": "No preference – include all fund types",
            "value": "no_preference",
            "etf_preference": "NONE"
          },
          {
            "id": "prefer_etf",
            "label": "I'd prefer ETFs where possible",
            "value": "prefer_etf",
            "etf_preference": "PREFER_ETF"
          },
          {
            "id": "etf_only",
            "label": "ETFs only – I want strictly index funds",
            "value": "etf_only",
            "etf_preference": "ETF_ONLY"
          }
        ]
      },
      {
        "id": "preferred_regions",
        "name": "Which regions would you like to invest in?",
        "description": "Select all that interest you. We'll use this to prioritize regional exposure while keeping the portfolio diversified.",
        "type": "multi_select",
        "required": false,
        "options": [
          {
            "id": "region_global",
            "label": "Global – spread across all major markets",
            "value": "global",
            "optimizer_region": "GLOBAL"
          },
          {
            "id": "region_europe",
            "label": "Europe – focus on European markets",
            "value": "europe",
            "optimizer_region": "EUROPE"
          },
          {
            "id": "region_north_america",
            "label": "North America – US and Canadian markets",
            "value": "north_america",
            "optimizer_region": "NORTH_AMERICA"
          },
          {
            "id": "region_emerging",
            "label": "Emerging Markets – high-growth developing economies",
            "value": "emerging_markets",
            "optimizer_region": "EMERGING_MARKETS"
          }
        ]
      },
      {
        "id": "preferred_themes",
        "name": "Are there any investment themes you're excited about?",
        "description": "Thematic funds focus on specific trends or sectors. These are satellite positions – they won't dominate your portfolio.",
        "type": "multi_select",
        "required": false,
        "options": [
          {
            "id": "theme_none",
            "label": "No specific theme – just a well-diversified portfolio",
            "value": "none",
            "optimizer_theme": "NONE"
          },
          {
            "id": "theme_sustainability",
            "label": "Sustainability & Climate – clean energy, environmental protection",
            "value": "sustainability",
            "optimizer_theme": "SUSTAINABILITY"
          },
          {
            "id": "theme_technology",
            "label": "Technology & Innovation – AI, semiconductors, digitalisation",
            "value": "technology",
            "optimizer_theme": "TECHNOLOGY"
          },
          {
            "id": "theme_healthcare",
            "label": "Healthcare & Life Sciences – biotech, medical devices, pharma",
            "value": "healthcare",
            "optimizer_theme": "HEALTHCARE"
          }
        ]
      }
    ]
  },
  "response_schema": {
    "portfolio_id": "string (UUID, auto-generated if not provided)",
    "created_at": "ISO 8601 timestamp",
    "updated_at": "ISO 8601 timestamp",
    "user_answers": {
      "investment_goal": "string (value from options)",
      "investment_duration": "string (value from options)",
      "monthly_savings": "string (value from options)",
      "investment_experience": [
        "array of strings (values from options)"
      ],
      "investment_knowledge": "string (value from options)",
      "risk_approach": "string (value from options)",
      "loss_tolerance": "string (value from options)",
      "esg_preference": "string (value from options: no_requirement | esg_basic | esg_enhanced)",
      "etf_preference": "string (value from options: no_preference | prefer_etf | etf_only)",
      "preferred_regions": [
        "array of strings (values from options: global | europe | north_america | emerging_markets)"
      ],
      "preferred_themes": [
        "array of strings (values from options: none | sustainability | technology | healthcare)"
      ]
    },
    "calculated_metrics": {
      "risk_profile": "integer (1-4)",
      "optimizer_profile": "string (DEFENSIVE | BALANCED | OPPORTUNITY)",
      "esg_requirement": "string (NONE | REQUIRED)",
      "esg_level": "string (null | BASIC | ENHANCED)",
      "etf_preference": "string (NONE | PREFER_ETF | ETF_ONLY)",
      "preferred_regions": ["array of optimizer Region values"],
      "preferred_themes": ["array of optimizer Theme values"],
      "suitable_fund_categories": [
        "array of recommended fund types"
      ],
      "diversification_needs": "string (conservative/moderate/aggressive)",
      "used_fallback_risk": "boolean (optional)"
    },
    "server_logs": [
      "array of strings capturing backend overrides or warnings"
    ]
  }
}
